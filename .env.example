# ---------------------------------------------------------------------------
# ESEMPIO di file .env
#
# COSA FARE:
#   1) Copia questo file e rinominalo in ".env" (senza ".example").
#   2) Incolla la tua chiave API di Anthropic al posto di "sk-ant-...".
#
# IMPORTANTE: il file .env NON va mai condiviso né caricato su Git/GitHub:
#             contiene un segreto (la tua chiave a pagamento).
# ---------------------------------------------------------------------------

# Chiave per il backend "claude" (lasciala pure cosi' se usi DeepSeek).
ANTHROPIC_API_KEY=sk-ant-incolla-qui-la-tua-chiave

# Chiave per il backend "deepseek". Ottienila su https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-incolla-qui-la-tua-chiave-deepseek
